@startuml
!theme plain
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #2C3E50
skinparam FontName Arial
skinparam FontSize 11

title Luồng chẩn đoán realtime khi học viên đang gõ

actor "Học viên\nđang gõ bài" as L
participant "Frontend\n(WritingInProgress)" as FE
participant "Backend\n(WritingRealtimeDiagnostics)" as BE
participant "Bộ phát hiện\nngôn ngữ" as LangDetect
participant "LanguageTool\n(ngữ pháp)" as LT
participant "Bộ phân tích\nquy tắc nội bộ" as Rule
participant "Bộ phân loại\ntừ vựng (CEFR)" as CEFR

== Gõ bài, debounce 1 giây ==
L -> FE : nhập từng ký tự
FE -> FE : debounce 1000ms,\nhủy request cũ nếu đang chờ

== Gửi chẩn đoán ==
FE -> BE : POST /practice/writing/diagnostics\n{ prompt_id, text }

BE -> LangDetect : phát hiện ngôn ngữ\n(tỉ lệ ký tự không phải ASCII)
LangDetect --> BE : { is_english, confidence }

alt không phải tiếng Anh
  BE --> FE : readiness: needs_work\nlý do: "Bài chưa giống tiếng Anh"
else tiếng Anh

  BE -> LT : kiểm tra ngữ pháp / chính tả
  alt LanguageTool sẵn sàng
    LT --> BE : danh sách lỗi + gợi ý
  else LanguageTool không khả dụng
    LT --> BE : lỗi kết nối
    BE -> BE : đánh dấu checked=false\ntotal_error_count=null
  end

  BE -> Rule : phân tích số từ, câu, đoạn,\ntừ nối, lời chào, lời kết, giọng điệu
  Rule --> BE : metrics (deterministic)

  BE -> CEFR : phân loại từ vựng theo CEFR
  CEFR --> BE : cefr_weighted_avg, advanced_ratio

  BE -> BE : heuristic kiểm tra yêu cầu đề bài\n(khớp từ khóa, độ phủ >= 35%)

  BE -> BE : tổng hợp readiness\n(từ? lời chào? ngữ pháp?\nLanguageTool có sẵn sàng không?)

  BE --> FE : { diagnostics, readiness, service_status }
end

== Hiển thị ==
FE -> FE : kiểm tra service_status.language_tool.checked
FE -> FE : kiểm tra null → hiện "Chưa kiểm tra"
FE -> FE : hiện số từ, yêu cầu đề bài,\ntrạng thái sẵn sàng nộp

L <-- FE : giao diện realtime cập nhật

@enduml
