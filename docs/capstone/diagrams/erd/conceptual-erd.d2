direction: right
auth: "Auth & Users" {
  users
  refresh_tokens
  device_tokens
  user_placements

  users -> refresh_tokens: "1:N"
  users -> device_tokens: "1:N"
  users -> user_placements: "1:1"
}

questions_kb: "Questions & Knowledge" {
  questions
  knowledge_points
  question_knowledge_points

  questions -> question_knowledge_points: "1:N"
  knowledge_points -> question_knowledge_points: "1:N"
}

exams_domain: "Exams & Sessions" {
  exams
  exam_sessions
  exam_answers
  exam_submissions

  exams -> exam_sessions: "1:N"
  exam_sessions -> exam_answers: "1:N"
  exam_sessions -> exam_submissions: "1:N"
}

submissions_domain: "Submissions & Grading" {
  submissions
  submission_details

  submissions -> submission_details: "1:1"
}

progress_domain: "Progress & Goals" {
  user_progress
  user_skill_scores
  user_goals
  user_knowledge_progress
}

classes_domain: "Classes & Feedback" {
  tbl_classes: "classes"
  class_members
  instructor_feedback

  tbl_classes -> class_members: "1:N"
  tbl_classes -> instructor_feedback: "1:N"
}

vocabulary_domain: "Vocabulary" {
  vocabulary_topics
  vocabulary_words
  user_vocabulary_progress

  vocabulary_topics -> vocabulary_words: "1:N"
  vocabulary_words -> user_vocabulary_progress: "1:N"
}

notifications_domain: "Notifications" {
  notifications
}

# ── Cross-domain relationships ────────────────────────────

auth.users -> questions_kb.questions: "creates 1:N"
auth.users -> exams_domain.exams: "creates 1:N"
auth.users -> submissions_domain.submissions: "1:N"
auth.users -> exams_domain.exam_sessions: "1:N"
auth.users -> progress_domain.user_progress: "1:N"
auth.users -> progress_domain.user_skill_scores: "1:N"
auth.users -> progress_domain.user_goals: "1:N"
auth.users -> progress_domain.user_knowledge_progress: "1:N"
auth.users -> classes_domain.tbl_classes: "owns 1:N"
auth.users -> classes_domain.class_members: "1:N"
auth.users -> classes_domain.instructor_feedback: "gives/receives 1:N"
auth.users -> notifications_domain.notifications: "1:N"
auth.users -> vocabulary_domain.user_vocabulary_progress: "1:N"

questions_kb.questions -> submissions_domain.submissions: "1:N"
questions_kb.questions -> exams_domain.exam_answers: "1:N"
questions_kb.knowledge_points -> progress_domain.user_knowledge_progress: "1:N"

submissions_domain.submissions -> exams_domain.exam_submissions: "1:N"
submissions_domain.submissions -> progress_domain.user_skill_scores: "1:N"
submissions_domain.submissions -> classes_domain.instructor_feedback: "0:N"

exams_domain.exam_sessions -> progress_domain.user_skill_scores: "1:N"
exams_domain.exam_sessions -> auth.user_placements: "0..1"
