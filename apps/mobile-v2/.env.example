# API origin only. Do not append /api/v1.
#
# Production / EAS:
# EXPO_PUBLIC_API_URL=https://api.vstepgo.com
#
# Local Backend V2:
# - Android emulator: http://10.0.2.2:8000
# - iOS simulator: http://localhost:8000
# - Physical phone: http://YOUR_COMPUTER_LAN_IP:8000
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
EXPO_PUBLIC_STORAGE_URL=https://your-r2-bucket.r2.dev

# Web OAuth client ID. Backend GOOGLE_CLIENT_ID must use the same value.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Backward-compatible alias if local .env already uses this name.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
