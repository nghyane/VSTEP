{
  "expo": {
    "name": "VSTEP",
    "slug": "vstep-mobile-v2",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vstep",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#58CC02"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vstep.mobile.v2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#58CC02"
      },
      "package": "com.vstep.mobile.v2",
      "softwareKeyboardLayoutMode": "pan",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-system-ui",
      [
        "expo-audio",
        {
          "microphonePermission": "Cho phep VSTEP su dung micro de luyen noi va ghi am bai speaking."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phep VSTEP su dung micro de luyen noi.",
          "speechRecognitionPermission": "Cho phep VSTEP nhan dien giong noi de luyen noi.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbb38b89-9f0c-4a0c-94e1-1b17d5554246"
      }
    },
    "owner": "khoiawesome"
  }
}
