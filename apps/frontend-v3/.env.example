VITE_API_URL=http://localhost:8010/api/v1

# Google OAuth 2.0 Client ID (Web application)
# Lấy từ: https://console.cloud.google.com/apis/credentials
# 1. Tạo project (hoặc chọn project hiện có)
# 2. APIs & Services → Credentials → Create Credentials → OAuth client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5175 (+ domain prod)
# 5. Copy Client ID (dạng xxxxx.apps.googleusercontent.com) dán vào đây
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
