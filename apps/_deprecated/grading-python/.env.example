# Primary: local proxy (OpenAI-compatible)
LLM_MODEL=openai/gpt-5.4
LLM_API_BASE=http://localhost:7860/api/provider/openai/v1
LLM_API_KEY=your-api-key

# Fallback: Cloudflare Workers AI (free, always available)
LLM_FALLBACK_MODEL=cloudflare/@cf/meta/llama-3.3-70b-instruct-fp8-fast
LLM_FALLBACK_ACCOUNT_ID=your-cloudflare-account-id
LLM_FALLBACK_API_KEY=your-cloudflare-api-key

STT_MODEL=cloudflare/@cf/deepgram/nova-3
STT_API_BASE=https://api.cloudflare.com/client/v4/accounts/<account_id>/ai
STT_API_KEY=your-cloudflare-api-key

REDIS_URL=redis://localhost:6379
