  <script is:inline>
    const tabs = document.querySelectorAll("[data-topic-tab]");
    const panels = document.querySelectorAll("[data-topic-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const activeTopic = tab.getAttribute("data-topic-tab");

        tabs.forEach((item) => {
          item.setAttribute("aria-selected", item === tab ? "true" : "false");
        });

        panels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-topic-panel") !== activeTopic;
        });
      });
    });

    async function copyText(text) {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand("copy");
      document.body.removeChild(textarea);
    }

    document.querySelectorAll("[data-copy-target]").forEach((button) => {
      button.addEventListener("click", async () => {
        const targetId = button.getAttribute("data-copy-target");
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;

        const originalLabel = button.textContent;
        await copyText(target.textContent || "");
        button.textContent = "Đã copy";
        setTimeout(() => {
          button.textContent = originalLabel;
        }, 1200);
      });
    });
  </script>
