};

const taskTypeLabels = {
  request: "Đề nghị",
  complaint: "Khiếu nại",
  apology: "Xin lỗi",
  application: "Ứng tuyển",
  invitation: "Mời",
  advice: "Lời khuyên",
  information_request: "Hỏi thông tin",
  thanks: "Cảm ơn",
  arrangement: "Sắp xếp",
  feedback: "Phản hồi",
  opinion: "Nêu quan điểm",
  problem_solution: "Vấn đề - giải pháp",
  discussion: "Thảo luận",
  advantage_disadvantage: "Ưu/nhược điểm",
  cause_effect: "Nguyên nhân - hệ quả",
};

const writingTopics = Object.entries(topicLabels)
  .map(([key, label]) => ({
    key,
    label,
    samples: writingSamples.filter((sample) => sample.topic === key),
  }))
  .filter((topic) => topic.samples.length > 0);

const formatSampleForCopy = (sample) => [
  `${sample.title} (${sample.level})`,
  `Part: Writing Task ${sample.part}`,
  `Dạng bài: ${taskTypeLabels[sample.taskType]}`,
  `Thời gian gợi ý: ${sample.estimatedMinutes} phút`,
  `Số từ: ${sample.minWords}-${sample.maxWords}`,
  "",
  "Đề bài:",
  sample.prompt,
  "",
  "Yêu cầu cần có:",
  ...sample.requiredPoints.map((point) => `- ${point}`),
  "",
  "Từ khóa:",
  sample.keywords.join(", "),
  "",
  "Câu mở đầu gợi ý:",
  ...sample.sentenceStarters.map((starter) => `- ${starter}`),
].join("\n");
