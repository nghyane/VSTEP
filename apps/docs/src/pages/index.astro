    requiredPoints: ["mô tả vấn đề sức khỏe hoặc học tập", "đề xuất giải pháp thực tế", "giải thích vì sao giải pháp hữu ích"],
    keywords: ["sinh viên", "giấc ngủ", "tập thể dục", "thiết bị số"],
    sentenceStarters: ["This can lead to...", "One solution is to...", "Schools and families can also..."],
    estimatedMinutes: 40,
  },
  {
    slug: "wt2-tourism-local-communities-b2",
    title: "Du lịch và cộng đồng địa phương",
    description: "Bài luận ưu điểm - nhược điểm về du lịch.",
    part: 2,
    taskType: "advantage_disadvantage",
    level: "B2",
    topic: "travel-tourism",
    prompt: "Du lịch mang lại thu nhập cho nhiều cộng đồng địa phương, nhưng cũng có thể tạo ra vấn đề môi trường và văn hóa. Du lịch có những ưu điểm và nhược điểm gì đối với người dân địa phương?",
    minWords: 250,
    maxWords: 350,
    requiredPoints: ["giải thích lợi ích kinh tế", "giải thích bất lợi về môi trường hoặc văn hóa", "đưa ví dụ"],
    keywords: ["du lịch", "cộng đồng địa phương", "thu nhập", "tác động môi trường"],
