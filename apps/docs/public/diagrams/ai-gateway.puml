@startuml
!theme plain
left to right direction
skinparam backgroundColor transparent
skinparam shadowing false
skinparam defaultFontName Arial
skinparam rectangle {
  BorderColor #e7e5e4
  FontColor #1c1917
  FontSize 12
}
skinparam component {
  BorderColor #e7e5e4
  FontColor #1c1917
  FontSize 12
}
skinparam ArrowColor #78716c

title AI Gateway — Sơ đồ thành phần

component "Dịch vụ nghiệp vụ\nWriting/Speaking/Conversation" as domain #E8F2FF
component "AI Gateway\nAiClientManager" as gateway #ECFDF3
component "Cấu hình AI\nservice → model → connection" as config #FFF3D8
component "Wire adapters\nMessages · Chat · Responses" as wire #F3E8FF
cloud "AI Providers" as provider #F5F5F0

domain -right-> gateway : toolCall()
gateway -down-> config : resolve
gateway -right-> wire : WireRequest
wire -right-> provider : HTTP API

note bottom of gateway
  Gateway tập trung retry,
  circuit breaker và logging.
end note

@enduml
